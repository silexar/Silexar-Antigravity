    "dompurify": "^3.3.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
