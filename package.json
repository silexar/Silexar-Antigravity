{
  "name": "silexar-pulse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --incremental",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky && node scripts/install-hooks.js",
    "security:scan": "node scripts/security-monitoring/continuous-security-scan.js",
    "security:watch": "node scripts/security-monitoring/continuous-security-scan.js watch",
    "security:health": "node scripts/security-monitoring/security-health-check.js",
    "security:health:ci": "node scripts/security-monitoring/security-health-check.js --ci",
    "security:fix": "node scripts/security-monitoring/auto-fix-security.js",
    "security:fix:dry": "node scripts/security-monitoring/auto-fix-security.js --dry-run",
    "security:metrics": "node scripts/security-monitoring/security-metrics-collector.js --dashboard",
    "security:metrics:export": "node scripts/security-monitoring/security-metrics-collector.js --export",
    "security:all": "npm run security:health && npm run security:scan && npm run security:metrics",
    "security:dashboard": "node scripts/security/security-dashboard.cjs",
    "security:dashboard:report": "node scripts/security/security-dashboard.cjs --report",
    "security:remediate": "node scripts/security/auto-remediate.cjs",
    "security:remediate:stats": "node scripts/security/auto-remediate.cjs --stats",
    "security:ci": "npm run security:health:ci && npm run lint && npm run check",
    "security:precommit": "lint-staged",
    "security:guard": "node scripts/guard-rails/pre-commit-guard.cjs",
    "security:build-check": "node scripts/guard-rails/build-validator.cjs",
    "postbuild": "npm run security:build-check",
    "security:full": "npm run security:ci && npm run test && npm run security:remediate && npm run security:dashboard:report",
    "security:autofix": "tsx scripts/security-autofix/cli.ts fix",
    "security:autofix:check": "tsx scripts/security-autofix/cli.ts check",
    "security:autofix:scan": "tsx scripts/security-autofix/cli.ts scan",
    "security:autofix:report": "tsx scripts/security-autofix/cli.ts report --format html --output security-report.html",
    "security:autofix:info": "tsx scripts/security-autofix/cli.ts info",
    "security:learning:init": "tsx scripts/init-security-learning.ts",
    "security:learning:stats": "tsx scripts/security-autofix/cli.ts learn stats",
    "security:audit": "node scripts/security-audit/audit.cjs",
    "security:audit:module": "node scripts/security-audit/audit.cjs --module",
    "security:audit:incremental": "node scripts/security-audit/audit.cjs --incremental",
    "security:audit:sarif": "node scripts/security-audit/audit.cjs --format=sarif",
    "security:audit:ci": "node scripts/security-audit/audit.cjs --ci",
    "security:audit:verbose": "node scripts/security-audit/audit.cjs --verbose",
    "security:semgrep": "semgrep --config=.agent/skills/security-audit/integrations/semgrep/semgrep-config.yml src/",
    "security:semgrep:ci": "semgrep --config=.agent/skills/security-audit/integrations/semgrep/semgrep-config.yml --error src/",
    "security:trivy:fs": "trivy fs --config=.agent/skills/security-audit/integrations/trivy/trivy-config.yaml .",
    "security:trivy:image": "trivy image --config=.agent/skills/security-audit/integrations/trivy/trivy-config.yaml",
    "security:trivy:config": "trivy config --config=.agent/skills/security-audit/integrations/trivy/trivy-config.yaml .",
    "security:trivy:all": "npm run security:trivy:fs && npm run security:trivy:config",
    "security:snyk:auth": "snyk auth",
    "security:snyk:test": "snyk test",
    "security:snyk:code": "snyk code test",
    "security:snyk:monitor": "snyk monitor",
    "security:snyk:container": "snyk container test",
    "security:snyk:iac": "snyk iac test",
    "security:dashboard:web": "npx serve .agent/skills/security-audit/dashboard -p 4567 -s"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
