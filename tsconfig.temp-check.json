{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "jsx": "react",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/app/api/cunas/[id]/route.ts",
    "src/app/api/contratos/smart-capture/route.ts",
    "src/app/api/cierre-mensual/route.ts",
    "src/app/api/activos-digitales/route.ts"
  ]
}
