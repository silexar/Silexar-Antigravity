# TIER 0 Enterprise Environment Configuration - Fortune 10 Grade
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME="SILEXAR PULSE QUANTUM"
NEXT_PUBLIC_APP_VERSION="2040.6.0"

# =============================================================================
# SECURITY CONFIGURATION - TIER 0
# =============================================================================

# JWT Configuration (RSA-256 Keys)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-long
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# Master Encryption Keys (AES-256)
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=your-64-character-hex-master-encryption-key-here
ENCRYPTION_KEY_DEFAULT=your-64-character-hex-default-encryption-key-here
ENCRYPTION_KEY_PII=your-64-character-hex-pii-encryption-key-here
ENCRYPTION_KEY_FINANCIAL=your-64-character-hex-financial-encryption-key-here
ENCRYPTION_KEY_MEDICAL=your-64-character-hex-medical-encryption-key-here
ENCRYPTION_KEY_LEGAL=your-64-character-hex-legal-encryption-key-here

# Secret Encryption Key for Local Caching
SECRET_ENCRYPTION_KEY=your-secret-encryption-key-for-local-caching

# =============================================================================
# AZURE KEY VAULT CONFIGURATION
# =============================================================================
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# =============================================================================
# DATABASE CONFIGURATION - POSTGRESQL
# =============================================================================
DATABASE_URL=postgresql://quantum_user:your-password@your-database-host:5432/silexar_quantum_db
DATABASE_HOST=your-database-host
DATABASE_PORT=5432
DATABASE_NAME=silexar_quantum_db
DATABASE_USERNAME=quantum_user
DATABASE_PASSWORD=your-super-secure-database-password

# SSL/TLS Certificates for Database (Production)
DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\nYOUR_CA_CERT_HERE\n-----END CERTIFICATE-----"
DATABASE_CLIENT_CERT="-----BEGIN CERTIFICATE-----\nYOUR_CLIENT_CERT_HERE\n-----END CERTIFICATE-----"
DATABASE_CLIENT_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_CLIENT_KEY_HERE\n-----END PRIVATE KEY-----"

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# =============================================================================
# OAUTH PROVIDERS CONFIGURATION
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Azure AD OAuth
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# =============================================================================
# NEXTAUTH CONFIGURATION
# =============================================================================
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret-minimum-32-characters-long

# =============================================================================
# MONITORING AND ANALYTICS
# =============================================================================

# Sentry for Error Monitoring
SENTRY_DSN=your-sentry-dsn
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Google Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# AWS SES
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# AWS S3
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=your-s3-access-key-id
AWS_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# =============================================================================
# EXTERNAL APIS
# =============================================================================

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=your-openai-organization

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# SECURITY FEATURES
# =============================================================================

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REDIS_URL=redis://your-redis-host:6379

# Geo Blocking
ENABLE_GEO_BLOCKING=true
BLOCKED_COUNTRIES=CN,RU,KP,IR

# Security Headers
FORCE_HTTPS=true
ENABLE_HSTS=true
ENABLE_CSP=true

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Logging
LOG_LEVEL=info
ENABLE_DEBUG_LOGS=false

# Quality Assurance
QUALITY_LOG_LEVEL=INFO
ENABLE_QUALITY_MONITORING=true

# Testing
ENABLE_TEST_MODE=false
TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/test_db

# =============================================================================
# PRODUCTION OPTIMIZATIONS
# =============================================================================

# Performance
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CACHE_TTL=3600

# CDN Configuration
CDN_URL=https://your-cdn-domain.com
ENABLE_CDN=true

# =============================================================================
# COMPLIANCE AND AUDIT
# =============================================================================

# Audit Logging
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years for compliance

# Data Retention
DATA_RETENTION_DAYS=2555
ENABLE_DATA_PURGING=true

# Compliance
ENABLE_GDPR_MODE=true
ENABLE_CCPA_MODE=true
ENABLE_SOX_COMPLIANCE=true

# =============================================================================
# BACKUP AND DISASTER RECOVERY
# =============================================================================

# Database Backups
ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=90

# File Backups
BACKUP_STORAGE_URL=s3://your-backup-bucket/
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Security Features
ENABLE_2FA=true
ENABLE_WEBAUTHN=true
ENABLE_DEVICE_TRACKING=true
ENABLE_ANOMALY_DETECTION=true

# AI Features
ENABLE_AI_THREAT_DETECTION=true
ENABLE_BEHAVIORAL_ANALYSIS=true
ENABLE_PREDICTIVE_SECURITY=true

# =============================================================================
# SOCIAL MEDIA INTEGRATION (RRSS MEDIA MODULE)
# =============================================================================

# AES-256-GCM secret for encrypting OAuth tokens at rest (min 32 chars)
RRSS_TOKEN_SECRET=your-64-character-hex-rrss-token-encryption-key-here

# Vercel Cron secret to authorize cron job requests
CRON_SECRET=your-random-cron-secret

# Meta (Facebook / Instagram) Graph API
META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://your-domain.com/api/rrss/callback/meta

# TikTok Business / Research API
TIKTOK_CLIENT_KEY=your-tiktok-client-key
NEXT_PUBLIC_TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=https://your-domain.com/api/rrss/callback/tiktok

# =============================================================================
# ENVIRONMENT SPECIFIC OVERRIDES
# =============================================================================

# Development
# NODE_ENV=development
# ENABLE_DEBUG_LOGS=true
# DISABLE_RATE_LIMITING=true

# Staging
# NODE_ENV=staging
# ENABLE_TEST_MODE=true
# REDUCED_RATE_LIMITS=true

# Production
# NODE_ENV=production
# ENABLE_ALL_SECURITY_FEATURES=true
# STRICT_MODE=true
# SMTP Email (for confirmations)
SMTP_HOST=smtp.mailserver.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
SMTP_FROM="Silexar Pulse <notifications@yourdomain.com>"
# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_ALLOWED_ORIGINS=http://localhost:3000

# Authentication
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=silexar_quantum_db
DATABASE_USERNAME=quantum_user
DATABASE_PASSWORD=quantum_password_2040
# Optional SSL
# DATABASE_CA_CERT=
# DATABASE_CLIENT_CERT=
# DATABASE_CLIENT_KEY=
