#!/usr/bin/env sh
# Silexar Pulse - Pre-push Hook
# Ejecuta tests completos y verificaciones de seguridad antes de push
# Bypass: git push --no-verify (solo para emergencias)

. "$(dirname -- "$0")/_/husky.sh"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color
BOLD='\033[1m'

echo ""
echo "${MAGENTA}${BOLD}🚀 ==========================================${NC}"
echo "${MAGENTA}${BOLD}🚀  SILEXAR PULSE PRE-PUSH HOOK${NC}"
echo "${MAGENTA}${BOLD}🚀 ==========================================${NC}"
echo ""

# Función para imprimir sección
print_section() {
    echo ""
    echo "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${CYAN}${BOLD}  $1${NC}"
    echo "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# Función para éxito
print_success() {
    echo "${GREEN}✅ $1${NC}"
}

# Función para error
print_error() {
    echo "${RED}❌ $1${NC}"
}

# Función para advertencia
print_warning() {
    echo "${YELLOW}⚠️  $1${NC}"
}

# Función para info
print_info() {
    echo "${BLUE}ℹ️  $1${NC}"
}

FAILED=0
START_TIME=$(date +%s)

# Obtener información del push
REMOTE="$1"
URL="$2"

echo "${BLUE}Remote: $REMOTE${NC}"
echo "${BLUE}URL: $URL${NC}"
echo ""

# ============================================
# 0. VERIFICAR RAMA PROTEGIDA
# ============================================
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "HEAD")

echo "${BLUE}Rama actual: $CURRENT_BRANCH${NC}"

# Ramas protegidas
PROTECTED_BRANCHES="main master production release"

for branch in $PROTECTED_BRANCHES; do
    if [ "$CURRENT_BRANCH" = "$branch" ]; then
        echo ""
        echo "${YELLOW}⚠️  ATENCIÓN: Estás en la rama '$branch'${NC}"
        echo "${YELLOW}   Asegúrate de que tus cambios están listos para producción${NC}"
        echo ""
        
        # En CI/CD, permitir el push
        if [ -n "$CI" ] || [ -n "$GITHUB_ACTIONS" ]; then
            print_info "Entorno CI/CD detectado, permitiendo push..."
        else
            # Preguntar confirmación (solo en terminal interactiva)
            if [ -t 0 ]; then
                printf "${YELLOW}¿Continuar con el push? [y/N]: ${NC}"
                read -r response
                case "$response" in
                    [yY][eE][sS]|[yY])
                        echo "Continuando..."
                        ;;
                    *)
                        echo "Push cancelado"
                        exit 1
                        ;;
                esac
            fi
        fi
        break
    fi
done

# ============================================
# 1. SECURITY AUDIT - npm audit
# ============================================
print_section "[1/6] Security Audit - Verificando vulnerabilidades en dependencias..."

npm audit --audit-level=high --silent 2>/dev/null
AUDIT_EXIT=$?

if [ $AUDIT_EXIT -ne 0 ]; then
    print_error "npm audit encontró vulnerabilidades HIGH/CRITICAL"
    echo ""
    echo "${YELLOW}💡 Para ver detalles:${NC}"
    echo "   npm audit"
    echo ""
    echo "${YELLOW}💡 Para intentar corregir automáticamente:${NC}"
    echo "   npm audit fix"
    echo ""
    FAILED=1
else
    print_success "No se encontraron vulnerabilidades HIGH/CRITICAL"
fi

# ============================================
# 2. LINT CHECK
# ============================================
if [ $FAILED -eq 0 ]; then
    print_section "[2/6] Lint Check - Verificando calidad del código..."
    
    npm run lint --silent 2>/dev/null
    LINT_EXIT=$?
    
    if [ $LINT_EXIT -ne 0 ]; then
        print_error "ESLint encontró errores"
        FAILED=1
    else
        print_success "ESLint pasó correctamente"
    fi
fi

# ============================================
# 3. TYPE CHECK
# ============================================
if [ $FAILED -eq 0 ]; then
    print_section "[3/6] Type Check - Verificando tipos de TypeScript..."
    
    if [ -f "tsconfig.json" ]; then
        npx tsc --noEmit --skipLibCheck 2>/dev/null
        TSC_EXIT=$?
        
        if [ $TSC_EXIT -ne 0 ]; then
            print_error "TypeScript encontró errores de tipo"
            FAILED=1
        else
            print_success "TypeScript check pasó correctamente"
        fi
    else
        print_warning "No se encontró tsconfig.json, saltando type check"
    fi
fi

# ============================================
# 4. UNIT TESTS
# ============================================
if [ $FAILED -eq 0 ]; then
    print_section "[4/6] Unit Tests - Ejecutando tests..."
    
    # Verificar si hay tests configurados
    if [ -f "vitest.config.ts" ] || [ -f "jest.config.js" ] || [ -f "vitest.config.js" ]; then
        echo "${BLUE}Ejecutando tests con cobertura mínima...${NC}"
        
        # Ejecutar tests sin watch mode
        npm run test -- --run --reporter=dot 2>/dev/null
        TEST_EXIT=$?
        
        if [ $TEST_EXIT -ne 0 ]; then
            print_error "Tests unitarios fallaron"
            FAILED=1
        else
            print_success "Todos los tests pasaron"
        fi
    else
        print_warning "No se encontró configuración de tests, saltando..."
    fi
fi

# ============================================
# 5. BUILD CHECK
# ============================================
if [ $FAILED -eq 0 ]; then
    print_section "[5/6] Build Check - Verificando que el proyecto compila..."
    
    # Solo verificar build en CI o si es una rama importante
    if [ -n "$CI" ] || [ -n "$GITHUB_ACTIONS" ] || [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
        echo "${BLUE}Ejecutando build de producción...${NC}"
        
        # Intentar build
        npm run build --silent 2>/dev/null
        BUILD_EXIT=$?
        
        if [ $BUILD_EXIT -ne 0 ]; then
            print_error "Build falló"
            FAILED=1
        else
            print_success "Build exitoso"
        fi
    else
        print_info "Saltando build check (solo en CI o rama main)"
    fi
fi

# ============================================
# 6. DETECTAR ARCHIVOS GRANDES
# ============================================
print_section "[6/6] Detectando archivos grandes..."

# Obtener archivos que se van a push
FILES_TO_PUSH=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")

if [ -n "$FILES_TO_PUSH" ]; then
    # Verificar archivos mayores a 1MB
    LARGE_FILES=$(git ls-files -s $FILES_TO_PUSH 2>/dev/null | awk '$4 > 1048576 {print $4, $5}' || echo "")
    
    if [ -n "$LARGE_FILES" ]; then
        print_warning "Se detectaron archivos grandes (>1MB):"
        echo "$LARGE_FILES"
        echo ""
        echo "${YELLOW}💡 Considera usar Git LFS para archivos grandes${NC}"
    else
        print_success "No se detectaron archivos grandes"
    fi
else
    print_info "No hay archivos para verificar"
fi

# ============================================
# RESUMEN FINAL
# ============================================
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo ""
echo "${MAGENTA}${BOLD}🚀 ==========================================${NC}"
echo "${MAGENTA}${BOLD}🚀  RESUMEN${NC}"
echo "${MAGENTA}${BOLD}🚀 ==========================================${NC}"
echo ""

if [ $FAILED -eq 0 ]; then
    echo "${GREEN}${BOLD}✅ TODOS LOS CHECKS PASARON${NC}"
    echo "${GREEN}✅ Push permitido${NC}"
    echo "${BLUE}⏱️  Tiempo total: ${DURATION}s${NC}"
    echo ""
    exit 0
else
    echo "${RED}${BOLD}🛑 PUSH BLOQUEADO${NC}"
    echo "${RED}🛑 Corrige los errores antes de continuar${NC}"
    echo "${BLUE}⏱️  Tiempo total: ${DURATION}s${NC}"
    echo ""
    echo "${YELLOW}💡 Para bypass de emergencia (solo si sabes lo que haces):${NC}"
    echo "   git push --no-verify"
    echo ""
    echo "${YELLOW}⚠️  ADVERTENCIA: El bypass puede exponer secretos o código vulnerable${NC}"
    echo ""
    exit 1
fi
