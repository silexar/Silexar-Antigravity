#!/usr/bin/env sh
# Silexar Pulse - Commit Message Hook
# Valida que los mensajes de commit sigan el formato convencional
# y no contengan información sensible

. "$(dirname -- "$0")/_/husky.sh"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Archivo con el mensaje de commit
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

echo ""
echo "${CYAN}${BOLD}📝 Validando mensaje de commit...${NC}"

# ============================================
# 1. VERIFICAR LONGITUD MÍNIMA Y MÁXIMA
# ============================================
MSG_LENGTH=${#COMMIT_MSG}

if [ $MSG_LENGTH -lt 10 ]; then
    echo "${RED}❌ Mensaje de commit demasiado corto (mínimo 10 caracteres)${NC}"
    exit 1
fi

if [ $MSG_LENGTH -gt 72 ]; then
    echo "${YELLOW}⚠️  Mensaje de commit muy largo (recomendado máximo 72 caracteres en la primera línea)${NC}"
fi

# ============================================
# 2. VERIFICAR QUE NO ESTÉ VACÍO O POR DEFECTO
# ============================================
if echo "$COMMIT_MSG" | grep -qE "^(Update|update|Fixed|fixed|Changes|changes|WIP|wip|TODO|todo|FIXME|fixme)"; then
    echo "${YELLOW}⚠️  Mensaje de commit muy genérico. Usa un mensaje más descriptivo.${NC}"
    echo ""
    echo "${BLUE}💡 Formatos recomendados:${NC}"
    echo "   feat: agrega función de autenticación OAuth"
    echo "   fix: corrige error en validación de email"
    echo "   docs: actualiza README con instrucciones de instalación"
    echo "   refactor: simplifica lógica de procesamiento de pagos"
    echo ""
fi

# ============================================
# 3. VERIFICAR QUE NO CONTENGA SECRETOS
# ============================================
# Patrones de secretos comunes en mensajes de commit
SENSITIVE_PATTERNS="
AKIA[0-9A-Z]{16}
gh[pousr]_[A-Za-z0-9_]{36,}
ghr_[A-Za-z0-9_]{36}
glpat-[0-9a-zA-Z\\-]{20}
sk-[a-zA-Z0-9]{48}
sk_(live|test)_[0-9a-zA-Z]{24,}
SG\\.[a-zA-Z0-9_-]{22}\\.[a-zA-Z0-9_-]{43}
SK[0-9a-fA-F]{32}
-----BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----
"

for pattern in $SENSITIVE_PATTERNS; do
    if echo "$COMMIT_MSG" | grep -qE "$pattern" 2>/dev/null; then
        echo "${RED}❌ ERROR CRÍTICO: Posible secreto detectado en el mensaje de commit${NC}"
        echo "${RED}❌ El mensaje de commit NO debe contener tokens, claves o contraseñas${NC}"
        exit 1
    fi
done

# ============================================
# 4. VERIFICAR CONVENCIONAL COMMITS (opcional pero recomendado)
# ============================================
CONVENTIONAL_PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|build|perf|revert)(\(.+\))?!?: .+"

if ! echo "$COMMIT_MSG" | grep -qE "$CONVENTIONAL_PATTERN"; then
    echo "${YELLOW}⚠️  El mensaje de commit no sigue el formato 'Conventional Commits'${NC}"
    echo ""
    echo "${BLUE}💡 Tipos permitidos:${NC}"
    echo "   feat:     Nueva característica"
    echo "   fix:      Corrección de bug"
    echo "   docs:     Cambios en documentación"
    echo "   style:    Cambios de formato (espacios, puntos y coma, etc)"
    echo "   refactor: Refactorización de código"
    echo "   test:     Agregar o corregir tests"
    echo "   chore:    Tareas de mantenimiento"
    echo "   ci:       Cambios en CI/CD"
    echo "   build:    Cambios en sistema de build"
    echo "   perf:     Mejoras de rendimiento"
    echo "   revert:   Revertir cambios"
    echo ""
    echo "${BLUE}💡 Ejemplos:${NC}"
    echo "   feat(auth): agrega login con Google OAuth"
    echo "   fix(api): corrige error 500 en endpoint /users"
    echo "   docs: actualiza guía de contribución"
    echo ""
    echo "${YELLOW}ℹ️  Puedes continuar, pero se recomienda usar el formato convencional${NC}"
    # No bloqueamos, solo advertimos
fi

# ============================================
# 5. VERIFICAR QUE NO HAYA PALABRAS PROHIBIDAS
# ============================================
PROHIBITED_WORDS="password123 secret123 admin123 qwerty 123456"

for word in $PROHIBITED_WORDS; do
    if echo "$COMMIT_MSG" | grep -qi "$word"; then
        echo "${YELLOW}⚠️  El mensaje de commit contiene palabras potencialmente sensibles${NC}"
        echo "${YELLOW}   Revisa que no estés incluyendo información confidencial${NC}"
        break
    fi
done

echo "${GREEN}✅ Mensaje de commit válido${NC}"
echo ""
exit 0
