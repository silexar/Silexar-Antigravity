#!/bin/sh
# 🔒 SILEXAR PULSE - PRE-COMMIT SECURITY HOOK
# Version: 2.0.0 | Tier: TIER_0_PENTAGON++

# Add Node.js to PATH (Windows local installation)
if [ -d "$HOME/AppData/Local/nodejs" ]; then
  export PATH="$HOME/AppData/Local/nodejs:$PATH"
fi

. "$(dirname "$0")/_/husky.sh"

echo "🔒 Silexar Pulse Security Pre-Commit Hook"
echo "=========================================="

# Run intelligent security guard
echo "🔒 Running Silexar Pulse Security Guard..."
node scripts/guard-rails/pre-commit-guard.cjs
GUARD_EXIT=$?

if [ $GUARD_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Security guard blocked the commit. Fix issues above before committing."
    exit 1
fi

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

# ═══════════════════════════════════════════════════════════════
# CHECK 1: Detectar secrets hardcodeados
# ═══════════════════════════════════════════════════════════════
echo ""
echo "🔐 [1/6] Scanning for hardcoded secrets..."

# Patterns de secrets
SECRET_PATTERNS="
sk_live_
sk_test_
password.*=.*['\"].*['\"]
token.*=.*['\"].*['\"]
api_key.*=.*['\"].*['\"]
secret.*=.*['\"].*['\"]
bearer\s+[a-zA-Z0-9_-]+
ghp_[a-zA-Z0-9]{36}
glpat-[a-zA-Z0-9-]{20}
"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|env)$' || true)

if [ -n "$STAGED_FILES" ]; then
    SECRETS_FOUND=$(echo "$STAGED_FILES" | xargs grep -l -E "$(echo $SECRET_PATTERNS | tr '\n' '|')" 2>/dev/null || true)
    
    if [ -n "$SECRETS_FOUND" ]; then
        echo "${RED}❌ FAIL: Potential secrets detected in:${NC}"
        echo "$SECRETS_FOUND"
        echo ""
        echo "${YELLOW}⚠️  If these are false positives, use:${NC}"
        echo "   git commit --no-verify"
        echo "   (Not recommended for production code)"
        FAILED=1
    else
        echo "${GREEN}✅ No hardcoded secrets detected${NC}"
    fi
else
    echo "${GREEN}✅ No relevant files staged${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# CHECK 2: Detectar console.log en código de producción
# ═══════════════════════════════════════════════════════════════
echo ""
echo "📝 [2/7] Checking for console statements..."

CONSOLE_FILES=$(echo "$STAGED_FILES" | xargs grep -l "console\.(log|warn|error|info)" 2>/dev/null | grep -v "\.test\." | grep -v "\.spec\." || true)

if [ -n "$CONSOLE_FILES" ]; then
    echo "${YELLOW}⚠️  WARNING: console statements found:${NC}"
    echo "$CONSOLE_FILES"
    echo ""
    echo "${YELLOW}   Consider using the logger utility instead${NC}"
    # No fallamos, solo advertimos
else
    echo "${GREEN}✅ No console statements found${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# CHECK 3: Security Autofix Check (AI-Powered)
# ═══════════════════════════════════════════════════════════════
echo ""
echo "🤖 [3/7] Running AI-powered security check..."

if command -v npx >/dev/null 2>&1; then
    # Run security autofix check in dry-run mode
    # This uses the learning system to detect and suggest fixes
    SECURITY_CHECK_OUTPUT=$(npx tsx scripts/security-autofix/cli.ts check 2>&1 || true)
    
    if echo "$SECURITY_CHECK_OUTPUT" | grep -q "HIGH"; then
        echo "${YELLOW}⚠️  HIGH severity security issues detected:${NC}"
        echo "$SECURITY_CHECK_OUTPUT" | tail -n 10
        echo ""
        echo "${YELLOW}💡 Run 'npm run security:autofix' to auto-fix issues${NC}"
        echo "${YELLOW}   or 'npm run security:autofix:check' for details${NC}"
        # Warning only - don't block commit
    else
        echo "${GREEN}✅ No critical security issues found${NC}"
    fi
else
    echo "${YELLOW}⚠️  Security autofix check skipped (npx not available)${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# CHECK 4: Validar que .env no se commitee
# ═══════════════════════════════════════════════════════════════
echo ""
echo "🔑 [4/7] Checking for environment files..."

ENV_FILES=$(git diff --cached --name-only | grep -E '\.env|\.env\.local|\.env\.production' || true)

if [ -n "$ENV_FILES" ]; then
    echo "${RED}❌ FAIL: Environment files should not be committed:${NC}"
    echo "$ENV_FILES"
    echo ""
    echo "${YELLOW}⚠️  Add them to .gitignore${NC}"
    FAILED=1
else
    echo "${GREEN}✅ No environment files staged${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# CHECK 5: Validar TypeScript
# ═══════════════════════════════════════════════════════════════
echo ""
echo "📘 [5/7] Running TypeScript checks..."

if npm run check 2>/dev/null | grep -q "error"; then
    echo "${RED}❌ FAIL: TypeScript errors found${NC}"
    echo "Run: npm run check"
    FAILED=1
else
    echo "${GREEN}✅ TypeScript checks passed${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# CHECK 6: Ejecutar lint-staged
# ═══════════════════════════════════════════════════════════════
echo ""
echo "🔍 [6/7] Running lint-staged..."

npx lint-staged || FAILED=1

# ═══════════════════════════════════════════════════════════════
# CHECK 7: Verificar tamaño de archivos
# ═══════════════════════════════════════════════════════════════
echo ""
echo "📦 [7/7] Checking file sizes..."

# Verificar archivos mayores a 500KB
LARGE_FILES=$(echo "$STAGED_FILES" | xargs -I {} sh -c 'stat -f%z "{}" 2>/dev/null || stat -c%s "{}" 2>/dev/null' | awk '$1 > 512000 {print}' || true)

if [ -n "$LARGE_FILES" ]; then
    echo "${YELLOW}⚠️  WARNING: Large files detected (>500KB)${NC}"
    echo "Consider optimizing these files"
else
    echo "${GREEN}✅ File sizes OK${NC}"
fi

# ═══════════════════════════════════════════════════════════════
# RESULTADO FINAL
# ═══════════════════════════════════════════════════════════════
echo ""
echo "=========================================="

if [ $FAILED -eq 0 ]; then
    echo "${GREEN}✅ ALL SECURITY CHECKS PASSED${NC}"
    echo "Proceeding with commit..."
    exit 0
else
    echo "${RED}❌ SECURITY CHECKS FAILED${NC}"
    echo ""
    echo "${YELLOW}Please fix the issues above before committing.${NC}"
    echo ""
    echo "To bypass (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    exit 1
fi
