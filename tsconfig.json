{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "incremental": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "class-validator": [
        "./node_modules/class-validator/types/index"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "src",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    // ── Standard exclusions ────────────────────────────────────────────────
    "backend",
    "node_modules",
    "dist",
    ".next",
    "_legacy_express",
    // ── Config files (not application code) ───────────────────────────────
    "vite.config.ts",
    "vite.config.*.ts",
    "vitest.config.ts",
    "vitest.config.*.ts",
    "quality-system-test.ts",
    // ── Test directories (Vitest/Playwright handle their own tsconfig) ─────
    "e2e",
    "tests",
    "test-*.ts",
    // Test files inside src/ — Vitest handles their compilation with vitest types
    // Note: these Jest-syntax tests need to be converted to Vitest (vi.mock, vi.fn)
    "src/**/__tests__",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    // ── Modules in progress — include as each module is completed ──────────
    // TODO SIL-300: fix TS errors in contratos module then remove this
    "src/modules/contratos",
    // TODO SIL-301: fix TS errors in agencias-creativas module then remove this
    "src/modules/agencias-creativas",
    // SIL-309 resolved: ICommand is now a proper marker interface in @/lib/cqrs
    // ── Scaffolding / speculative code — needs refactor before inclusion ───
    // TODO SIL-302: audit and include emergency module
    "src/lib/emergency",
    // TODO SIL-303: audit and include integrations module
    "src/lib/integrations",
    // TODO SIL-304: audit and include monitoring module
    "src/lib/monitoring",
    // TODO SIL-305: audit and include offline module
    "src/lib/offline",
    // TODO SIL-306: audit and include performance module
    "src/lib/performance",
    // TODO SIL-307: audit and include sprint planning tools
    "src/lib/sprint",
    // ── Files with unresolved 3rd-party dependencies ───────────────────────
    // security-tests.ts is a manual test runner, not production code
    "src/lib/security/security-tests.ts",
    // exportador-dalet.ts depends on external DALET SDK not yet installed
    "src/lib/services/exportador-dalet.ts",
    // api/ at root level is legacy Express code — migrated to Next.js App Router
    "api"
  ]
}
