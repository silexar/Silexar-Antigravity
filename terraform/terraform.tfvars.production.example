# Production Environment Configuration
project_id   = "silexar-pulse-prod"
region       = "us-central1"
environment  = "production"

# GKE Configuration
gke_num_nodes    = 3
gke_min_nodes    = 2
gke_max_nodes    = 10
gke_machine_type = "n2-standard-4"  # 4 vCPUs, 16 GB RAM

# Cloud SQL Configuration
db_tier      = "db-custom-4-16384"  # 4 vCPUs, 16 GB RAM
db_disk_size = 100                   # GB
db_username  = "silexar_admin"
db_password  = "CHANGE_THIS_SECURE_PASSWORD_123!"  # ⚠️ CAMBIAR ESTO

# Redis Configuration
redis_memory_size = 5  # GB
