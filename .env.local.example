# Logging Configuration
NODE_ENV=development
LOGGING_LEVEL=info
ENABLE_AI_INITIALIZATION_LOGS=true
ENABLE_AI_ROUTINE_LOGS=false
ENABLE_AI_CRITICAL_LOGS=true

# AI System Throttling (in milliseconds)
AI_INIT_LOG_INTERVAL=60000
AI_ROUTINE_LOG_INTERVAL=300000
AI_CRITICAL_LOG_INTERVAL=1000

# Log Batching
ENABLE_LOG_BATCHING=true
LOG_BATCH_SIZE=10
LOG_FLUSH_INTERVAL=30000

# ============================================
# 🔐 BETTER AUTH CONFIGURATION (Development)
# ============================================

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/silexar_pulse

# Better Auth Secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-development-auth-secret-key

# JWT Secrets — use SEPARATE secrets for access and refresh tokens (security best practice)
# Generate each with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-development-access-secret-min-32-chars-here
JWT_REFRESH_SECRET=your-development-refresh-secret-min-32-chars-here
# Legacy fallback (used if JWT_ACCESS_SECRET / JWT_REFRESH_SECRET not set)
JWT_SECRET=your-development-jwt-secret-min-32-chars-here

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth Providers (optional - for local testing)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Cookie Domain (leave empty for localhost)
# COOKIE_DOMAIN=

# Redis (optional - for rate limiting in development)
# REDIS_URL=redis://localhost:6379

# ============================================
# 🔐 DEV 2FA — Mock login component (dev only)
# ============================================
# Base-32 TOTP secret for the dev mock login user (user_001 / maria@empresa.com).
# Generate a random secret:  openssl rand -base64 15 | tr '+/=' 'A-Z2-7' | head -c 32
# Add this secret to your authenticator app (Google Authenticator / Authy / etc.)
# to get real 6-digit codes during development.
#
# To print the current valid code from the terminal:
#   node -e "const c=require('crypto');const s=Buffer.from('YOUR_SECRET_HERE','base32');const ct=Math.floor(Date.now()/30000);const b=Buffer.alloc(8);b.writeUInt32BE(Math.floor(ct/2**32),0);b.writeUInt32BE(ct>>>0,4);const h=c.createHmac('sha1',s).update(b).digest();const o=h[h.length-1]&0xf;console.log(String((h.readUInt32BE(o)&0x7fffffff)%1000000).padStart(6,'0'))"
#
DEV_2FA_SECRET=JBSWY3DPEHPK3PXP   # Example — replace with your own generated secret